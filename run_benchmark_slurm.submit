#!/bin/bash
#SBATCH --time=600
#SBATCH --job-name=energy_bench
#SBATCH --ntasks=1
#SBATCH --nodes=1
#SBATCH --account=init
#SBATCH --gres=gpu:1
#SBATCH --output=log/%j_%N__energy_bench.out
#SBATCH --error=log/%j_%N__energy_bench.err

# Set the root folder for the project (configurable via env vars)
ROOT_FOLDER="${ROOT_FOLDER:-/path/to/sw-energy-benchmark}"
UV_PATH="${UV_PATH:-$HOME/.local/bin/uv}"

# Derive config file: array mode (SLURM_ARRAY_TASK_ID + BATCH_CONFIG_DIR) or CLI arg
if [ -n "${SLURM_ARRAY_TASK_ID:-}" ] && [ -n "${BATCH_CONFIG_DIR:-}" ]; then
    CONFIG_FILE=$(printf "%s/config_batch_%03d.yaml" "$BATCH_CONFIG_DIR" "$SLURM_ARRAY_TASK_ID")
else
    CONFIG_FILE=${1:-config.yaml}
fi

echo "Using config file: $CONFIG_FILE"

# --- Script Start ---
# For array jobs, include the task ID to ensure unique directories per task
if [ -n "${SLURM_ARRAY_TASK_ID:-}" ]; then
    JOB_UNIQUE_ID="${SLURM_ARRAY_JOB_ID}_${SLURM_ARRAY_TASK_ID}"
else
    JOB_UNIQUE_ID="$SLURM_JOB_ID"
fi
echo "[$(date)] Starting Job ID: $JOB_UNIQUE_ID"

# Create a job-specific virtual environment in a temporary directory
VENV_DIR="/tmp/sw-energy-benchmark-venv-$JOB_UNIQUE_ID"
mkdir -p "$VENV_DIR"
"$UV_PATH" venv "$VENV_DIR"
source "$VENV_DIR/bin/activate"

# Set up a trap to clean up the virtual environment on exit
trap 'rm -rf -- "$VENV_DIR"' EXIT

# --- GPU-Specific Dependency Installation ---

# First, check if nvidia-smi is available to prevent errors
if ! command -v nvidia-smi &> /dev/null
then
    echo "nvidia-smi command not found. Cannot detect GPU type. Exiting."
    exit 1
fi

# Detect the GPU name. We only query for one GPU since we requested one (--gres=gpu:1).
GPU_NAME=$(nvidia-smi --query-gpu=gpu_name --format=csv,noheader,nounits | head -n 1)
echo "Detected GPU: $GPU_NAME"

# --- GPU Variant Validation ---
if [ -n "${EXPECTED_GPU:-}" ]; then
    GPU_MISMATCH=false
    case "$EXPECTED_GPU" in
        H100_SXM)
            if echo "$GPU_NAME" | grep -qi "pcie"; then
                GPU_MISMATCH=true
            fi
            ;;
        H100_PCIe)
            if ! echo "$GPU_NAME" | grep -qi "pcie"; then
                GPU_MISMATCH=true
            fi
            ;;
    esac
    if [ "$GPU_MISMATCH" = true ]; then
        echo "[$(date)] GPU MISMATCH: Expected $EXPECTED_GPU but got '$GPU_NAME'. Exiting with code 42."
        exit 42
    fi
    echo "[$(date)] GPU match confirmed: Expected $EXPECTED_GPU, got '$GPU_NAME'"
fi

# All GPUs use the same modern requirements file
REQS_FILE="$ROOT_FOLDER/requirements_modern.txt"
echo "Using requirements: $REQS_FILE"

# Check if the selected requirements file exists
if [ ! -f "$REQS_FILE" ]; then
    echo "Error: Requirements file not found at $REQS_FILE"
    exit 1
fi

# Install dependencies into the virtual environment
echo "Installing dependencies from: $REQS_FILE"
"$UV_PATH" pip install -r "$REQS_FILE"
echo "Dependencies installed successfully."

# Set LD_LIBRARY_PATH for CUDA libraries in the venv
SITE_PACKAGES="$VENV_DIR/lib/python3.11/site-packages"
export LD_LIBRARY_PATH="$SITE_PACKAGES/nvidia/cusparselt/lib:$SITE_PACKAGES/nvidia/cublas/lib:$SITE_PACKAGES/nvidia/cusparse/lib:$SITE_PACKAGES/nvidia/cudnn/lib:$LD_LIBRARY_PATH"

# Set up Hugging Face home to share model downloads across jobs
HF_HOME_DIR="${HF_HOME_DIR:-/path/to/shared/huggingface-cache}"
mkdir -p "$HF_HOME_DIR"
export HF_HOME="$HF_HOME_DIR"

## DOWNLOADING MODELS BEFORE
# --- Configuration ---
ENV_FILE=".env"

# 1. Check if the YAML file exists
if [ ! -f "$CONFIG_FILE" ]; then
    echo "Error: YAML file not found at '$CONFIG_FILE'"
    exit 1
fi

# 2. Check if the .env file exists and load the token
if [ -f "$ENV_FILE" ]; then
    set -a
    source "$ENV_FILE"
    set +a
    echo "Loaded HF_TOKEN from $ENV_FILE."
else
    echo "Warning: .env file not found. Will try to proceed without a token."
    echo "This may fail for gated models like Llama or Gemma."
fi

# 3. Check if HF_TOKEN is set in the environment
if [ -z "$HF_TOKEN" ]; then
    echo "-----------------------------------------------------"
    echo "Warning: HF_TOKEN is not set."
    echo "Gated models will likely fail to download."
    echo "If you need them, create a .env file with HF_TOKEN=your_token"
    echo "-----------------------------------------------------"
fi

# 4. Parse the YAML file and download each model
echo "Parsing models from $CONFIG_FILE..."

MODELS_TO_DOWNLOAD=$(awk '
  /^LLM_MODELS:/ { in_models_block = 1; next }
  /^[A-Z_]+:/ { in_models_block = 0 }
  in_models_block && /^\s*-\s*"/ && !/^\s*#/ {
    match($0, /"([^"]+)"/);
    if (RSTART) {
      print substr($0, RSTART + 1, RLENGTH - 2);
    }
  }
' "$CONFIG_FILE")

for model in $MODELS_TO_DOWNLOAD; do
    echo "====================================================="
    echo "Preparing to download: $model"
    echo "====================================================="

    huggingface-cli download "$model" --token "$HF_TOKEN"

    if [ $? -eq 0 ]; then
        echo "--> SUCCESS: Successfully downloaded $model."
    else
        echo "--> ERROR: Failed to download $model. Please check logs for details."
    fi
done

echo ""
echo "====================================================="
echo "All model downloads attempted. Process finished."
echo "====================================================="

# --- Build descriptive result folder path ---
# GPU label: prefer EXPECTED_GPU (clean), fall back to sanitized nvidia-smi name
if [ -n "${EXPECTED_GPU:-}" ]; then
    GPU_LABEL="$EXPECTED_GPU"
else
    GPU_LABEL=$(echo "$GPU_NAME" | sed 's/^NVIDIA //;s/ /_/g;s/[^A-Za-z0-9._-]/_/g')
fi

# Config label: passed from orchestrator via env, fall back to "unknown_config"
CONFIG_LABEL="${CONFIG_BASENAME:-unknown_config}"

# Run label groups all jobs from the same config+GPU run
RUN_LABEL="${CONFIG_LABEL}__${GPU_LABEL}"

# Model slug: use first model's short name (part after '/'), sanitize.
# If batch has >1 model, fall back to the batch config filename (e.g. config_batch_003).
model_count=$(echo "$MODELS_TO_DOWNLOAD" | grep -c . || true)
if [ "$model_count" -eq 1 ]; then
    MODEL_SLUG=$(echo "$MODELS_TO_DOWNLOAD" | awk -F'/' '{print $NF}' | sed 's/[^A-Za-z0-9._-]/_/g')
else
    MODEL_SLUG=$(basename "$CONFIG_FILE" .yaml)
fi
[ -z "$MODEL_SLUG" ] && MODEL_SLUG="$JOB_UNIQUE_ID"

JOB_RESULTS_FOLDER="$ROOT_FOLDER/results/$RUN_LABEL/${JOB_UNIQUE_ID}__${MODEL_SLUG}"
mkdir -p "$JOB_RESULTS_FOLDER"
echo "[$(date)] Results will be stored in: $JOB_RESULTS_FOLDER"

# Define the path for the system info file within the unique job folder
RESULTS_FILE="$JOB_RESULTS_FOLDER/system_info.txt"

# ---------------------------------------
# Register system info.
# ---------------------------------------
echo "[$(date)] Registering system info..."

echo "lscpu" > "$RESULTS_FILE"
lscpu >> "$RESULTS_FILE"
echo -e "\n" >> "$RESULTS_FILE"

echo "nvidia-smi -q" >> "$RESULTS_FILE"
nvidia-smi -q >> "$RESULTS_FILE"
echo -e "\n" >> "$RESULTS_FILE"

echo "free -h" >> "$RESULTS_FILE"
free -h >> "$RESULTS_FILE"
echo -e "\n" >> "$RESULTS_FILE"

echo "df -h" >> "$RESULTS_FILE"
df -h >> "$RESULTS_FILE"
echo -e "\n" >> "$RESULTS_FILE"

echo "[$(date)] System info registered in $RESULTS_FILE"

# ---------------------------------------
# Run the Python scripts for language
echo "[$(date)] Running llm_server_optimized.py..."
srun --export=ALL python "$ROOT_FOLDER/language/llm_server_optimized.py" "$JOB_RESULTS_FOLDER" --config "$CONFIG_FILE" > "$JOB_RESULTS_FOLDER/llm_server_optimized.out"
if [ $? -ne 0 ]; then
    echo "[$(date)] ERROR: llm_server_optimized.py failed. Exiting with code 1."
    exit 1
fi

echo "[$(date)] Running llm_batch_optimized.py..."
srun --export=ALL python "$ROOT_FOLDER/language/llm_batch_optimized.py" "$JOB_RESULTS_FOLDER" --config "$CONFIG_FILE" > "$JOB_RESULTS_FOLDER/llm_batch_optimized.out"
if [ $? -ne 0 ]; then
    echo "[$(date)] ERROR: llm_batch_optimized.py failed. Exiting with code 1."
    exit 1
fi

echo "[$(date)] Job Finished"
